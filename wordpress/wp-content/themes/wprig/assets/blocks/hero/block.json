{
  "name": "wp-rig/hero",
  "apiVersion": 2,
  "title": "Hero",
  "category": "design",
  "icon": "cover-image",
  "description": "A custom hero section with heading, subheading, and background image",
  "textdomain": "wp-rig",
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "subheading": {
      "type": "string",
      "default": ""
    },
    "backgroundImageUrl": {
      "type": "string",
      "default": ""
    },
    "backgroundImageId": {
      "type": "number",
      "default": 0
    },
    "backgroundImageAlt": {
      "type": "string",
      "default": ""
    },
    "primaryButtonText": {
      "type": "string",
      "default": ""
    },
    "primaryButtonUrl": {
      "type": "string",
      "default": ""
    },
    "secondaryButtonText": {
      "type": "string",
      "default": ""
    },
    "secondaryButtonUrl": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./build/index.js",
  "style": "file:./build/style.css",
  "editorStyle": "file:./build/editor.css",
  "render": "file:./render.php",
  "supports": {
    "align": ["full"],
    "spacing": false,
    "color": false
  }
}
